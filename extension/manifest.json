{
  "manifest_version": 3,
  "name": "Non-Latin Text Remover",
  "version": "1.0",
  "description": "Automatically removes non-Latin script text from webpages.",
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
